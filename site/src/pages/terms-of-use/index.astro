---
import Layout from "../../layouts/Layout.astro";
---

<Layout
	lang="en"
	title="Terms of Use | chesson.me"
	description="Terms of Use for chesson.me online chess service."
	canonicalUrl="https://chesson.me/terms-of-use/"
	ogImage="https://chesson.me/og.png"
	locale="en_US"
	alternates={[
		{ lang: "en", url: "https://chesson.me/terms-of-use/" },
		{ lang: "ru", url: "https://chesson.me/ru/terms-of-use/" },
		{ lang: "x-default", url: "https://chesson.me/terms-of-use/" },
	]}
>
	<main class="bg-[#070707] text-white min-h-screen">
		<section class="mx-auto w-[calc(100%-2rem)] max-w-4xl py-14 sm:py-20">
			<h1 class="text-3xl sm:text-4xl font-bold">Terms of Use</h1>
			<p class="mt-4 text-white/70">Last updated: April 18, 2026</p>

			<div class="mt-10 space-y-10 text-white/85 leading-relaxed">
				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">1. General Provisions</h2>
					<p class="mt-3">
						The chesson.me service provides users with the ability to play chess online.
					</p>
					<p class="mt-3">By using the website, you agree to these Terms.</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">2. Service Usage</h2>
					<p class="mt-3">You agree to:</p>
					<ul class="mt-3 list-disc pl-5 space-y-2">
						<li>Not use the website for illegal activity</li>
						<li>Not disrupt service operation</li>
						<li>Not use automated scripts without permission</li>
					</ul>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">3. Service Availability</h2>
					<p class="mt-3">The service is provided "as is".</p>
					<p class="mt-3">We do not guarantee:</p>
					<ul class="mt-3 list-disc pl-5 space-y-2">
						<li>Uninterrupted operation</li>
						<li>Absence of errors</li>
						<li>Permanent availability</li>
					</ul>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">4. Limitation of Liability</h2>
					<p class="mt-3">chesson.me is not liable for:</p>
					<ul class="mt-3 list-disc pl-5 space-y-2">
						<li>Any losses arising from website usage</li>
						<li>Technical failures</li>
						<li>Data loss</li>
					</ul>
					<p class="mt-3">The user uses the service at their own risk.</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">5. Service Changes</h2>
					<p class="mt-3">We may at any time:</p>
					<ul class="mt-3 list-disc pl-5 space-y-2">
						<li>Change functionality</li>
						<li>Add or remove features</li>
						<li>Temporarily or permanently disable the service</li>
					</ul>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">6. Terms Updates</h2>
					<p class="mt-3">
						We may update these Terms of Use.
					</p>
					<p class="mt-3">
						By continuing to use the website, you agree to the current version of the Terms.
					</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">7. Contacts</h2>
					<p class="mt-3">
						Email: <a href="mailto:notifications@chesson.me" class="underline underline-offset-4 hover:text-white">notifications@chesson.me</a>
					</p>
				</section>
			</div>
		</section>
	</main>
</Layout>
