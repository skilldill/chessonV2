---
import Layout from "../layouts/Layout.astro";
import { Chessboard3D } from "../components/Chessboard3D";

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: [
		{
			"@type": "Question",
			name: "Can I play chess online for free?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "Yes. You can start and play chess online for free on chesson.me.",
			},
		},
		{
			"@type": "Question",
			name: "Do I need registration to start?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "No. You can start a game without mandatory registration.",
			},
		},
		{
			"@type": "Question",
			name: "Can I play against a bot?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "Yes. You can play online chess with a computer and choose a suitable difficulty level.",
			},
		},
		{
			"@type": "Question",
			name: "Does it work on mobile and desktop?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "Yes. chesson.me works in modern mobile and desktop browsers.",
			},
		},
	],
};
---

<Layout 
	lang="en" 
	title="Play Chess Online for Free — chesson.me"
	description="Play chess online without registration. Random opponents, games vs bot, and AI-powered hints."
	canonicalUrl="https://chesson.me/"
	ogImage="https://chesson.me/og.png"
	locale="en_US"
	alternates={[
		{ lang: "en", url: "https://chesson.me/" },
		{ lang: "ru", url: "https://chesson.me/ru/" },
		{ lang: "x-default", url: "https://chesson.me/" },
	]}
>
	<main class="bg-[#070707] text-white">
		<section class="relative w-full h-screen overflow-hidden">
			<header class="absolute top-0 left-0 right-0 z-10 p-9">
				<nav class="flex justify-between items-center max-w-6xl mx-auto">
					<div class="flex items-center">
						<img src="/chesson-logo.svg" alt="Chesson Logo" />
					</div>
				</nav>
			</header>
			<div
				class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-10 text-center w-[calc(100%-2rem)] max-w-4xl flex flex-col justify-center items-center h-full"
			>
				<h1 class="font-bold mb-8 max-w-4xl mx-auto text-3xl sm:text-4xl md:text-5xl lg:text-7xl">
					Play chess online free <br> vs players or bot
				</h1>
				<h2 class="mb-10 font-normal text-3xl">
					Create a room in seconds and start a game without registration
				</h2>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 w-full sm:w-auto">
					<a
						id="create-room-btn"
						href="https://game.chesson.me/"
						class="w-full sm:w-auto bg-white text-black font-bold py-3 px-6 rounded-md hover:bg-gray-200 transition duration-300 text-lg cursor-pointer"
					>
						Play
					</a>
				</div>
			</div>
			<Chessboard3D client:idle />
			<div class="absolute left-0 bottom-[40px] right-0 z-[10]">
				<div class="text-center text-xm opacity-70 flex flex-col md:flex-row items-center justify-center gap-1 md:gap-[14px]">
					<a href="https://t.me/chessonme" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 transition-opacity order-1 md:order-3">
						<span class="order-2 md:order-1">v0.22.0 + <span class="font-extrabold bg-gradient-to-r from-[#E810A7] to-[#FFE600] bg-clip-text text-transparent italic">AI features</span></span>
					</a>
				</div>
			</div>
		</section>

		<section class="mx-auto w-[calc(100%-2rem)] max-w-6xl py-16 sm:py-20">
			<div class="mb-8 sm:mb-10">
				<h2 class="mt-3 text-2xl sm:text-3xl md:text-4xl font-semibold">Everything to start a chess game fast</h2>
			</div>

			<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
				<article class="rounded-2xl border border-[#252525] bg-[#0F0F0F] p-6 sm:p-7 lg:col-span-2">
					<h3 class="text-xl sm:text-2xl font-semibold">Create Tournament Bracket for Offline Play</h3>
					<p class="mt-3 text-white/75 leading-relaxed">
						Use the bracket tool to organize offline chess games, track rounds, and manage winners in one place.
					</p>
					<a
						href="/tournaments"
						class="mt-6 inline-flex w-full items-center justify-center rounded-md bg-white px-5 py-2.5 font-semibold text-black hover:bg-gray-200 transition-colors"
					>
						Create Tournament Bracket
					</a>
				</article>

				<article class="rounded-2xl border border-[#252525] bg-[#0F0F0F] p-6 sm:p-7">
					<h3 class="text-xl font-semibold">Play instantly</h3>
					<p class="mt-3 text-white/75">No registration. Random opponents, bot games, and AI-powered hints.</p>
					<a
						id="cta-play-now-btn"
						href="https://game.chesson.me/"
						class="mt-6 inline-flex w-full items-center justify-center rounded-md bg-white px-5 py-2.5 font-semibold text-black hover:bg-gray-200 transition-colors"
					>
						Play now
					</a>
				</article>

				<article class="rounded-2xl border border-[#252525] bg-[#0F0F0F] p-6 sm:p-7">
					<h3 class="text-xl font-semibold">Random opponent online</h3>
					<p class="mt-3 text-white/75">Jump into a live match and start playing in seconds.</p>
				</article>

				<article class="rounded-2xl border border-[#252525] bg-[#0F0F0F] p-6 sm:p-7">
					<h3 class="text-xl font-semibold">Play with a bot</h3>
					<p class="mt-3 text-white/75">Train against 3 difficulty levels and improve at your own pace.</p>
				</article>

				<article class="rounded-2xl border border-[#252525] bg-[#0F0F0F] p-6 sm:p-7">
					<h3 class="text-xl font-semibold">AI-powered hints</h3>
					<p class="mt-3 text-white/75">Get practical guidance during play and learn faster.</p>
				</article>

				<article class="rounded-2xl border border-[#252525] bg-[#0F0F0F] p-6 sm:p-7 lg:col-span-3">
					<h3 class="text-xl sm:text-2xl font-semibold">Why chesson?</h3>
					<div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4 text-sm">
						<p class="rounded-xl border border-[#222] bg-[#121212] px-4 py-3">Play without registration</p>
						<p class="rounded-xl border border-[#222] bg-[#121212] px-4 py-3">Start games instantly</p>
						<p class="rounded-xl border border-[#222] bg-[#121212] px-4 py-3">Works on mobile and desktop</p>
						<p class="rounded-xl border border-[#222] bg-[#121212] px-4 py-3">Free and unlimited</p>
					</div>
				</article>
			</div>
		</section>

		<section class="mx-auto w-[calc(100%-2rem)] max-w-6xl pb-16 sm:pb-20" aria-labelledby="faq-title">
			<div class="rounded-2xl border border-[#252525] bg-[#0F0F0F] p-6 sm:p-8">
				<h2 id="faq-title" class="text-2xl sm:text-3xl font-semibold">FAQ</h2>
				<div class="mt-6 grid gap-3 md:grid-cols-2">
					<details class="rounded-xl border border-[#222] bg-[#121212] px-4 py-3">
						<summary class="cursor-pointer font-semibold">Can I play chess online for free?</summary>
						<p class="mt-2 text-white/80">Yes. You can start and play chess online for free on chesson.me.</p>
					</details>
					<details class="rounded-xl border border-[#222] bg-[#121212] px-4 py-3">
						<summary class="cursor-pointer font-semibold">Do I need registration to start?</summary>
						<p class="mt-2 text-white/80">No. You can start a game without mandatory registration.</p>
					</details>
					<details class="rounded-xl border border-[#222] bg-[#121212] px-4 py-3">
						<summary class="cursor-pointer font-semibold">Can I play against a bot?</summary>
						<p class="mt-2 text-white/80">Yes. You can play online chess with a computer and choose a suitable difficulty level.</p>
					</details>
					<details class="rounded-xl border border-[#222] bg-[#121212] px-4 py-3">
						<summary class="cursor-pointer font-semibold">Does it work on mobile and desktop?</summary>
						<p class="mt-2 text-white/80">Yes. chesson.me works in modern mobile and desktop browsers.</p>
					</details>
				</div>
			</div>
		</section>

		<section class="mx-auto w-[calc(100%-2rem)] max-w-6xl pb-16 sm:pb-20" aria-labelledby="seo-text-title">
			<div class="rounded-2xl border border-[#252525] bg-[#0F0F0F] p-6 sm:p-8 text-sm sm:text-base leading-relaxed text-white/85">
				<h2 id="seo-text-title" class="text-xl sm:text-2xl font-semibold text-white">Play Chess Online in Seconds</h2>
				<p class="mt-4">
					On chesson.me, you can <strong>play chess online</strong> right in your browser in just a few clicks. The platform is built for quick daily matches and longer evening games.
				</p>
				<p class="mt-4">
					If you are looking for <strong>online chess for free</strong>, you can jump straight into a game: create a room, find an opponent, or start a match versus a bot. It is a simple <strong>chess game without registration</strong> and no unnecessary setup.
				</p>
				<p class="mt-4">
					You can also play <strong>online chess with a computer</strong> to train tactics and practice at your own pace. The service works smoothly on both mobile and desktop, so you can play anywhere.
				</p>
			</div>
		</section>

		<footer class="border-t border-white/10" aria-label="Footer links">
			<div class="mx-auto w-[calc(100%-2rem)] max-w-6xl py-12 sm:py-14">
				<div class="grid gap-10 lg:grid-cols-6">
					<div class="lg:col-span-2">
						<div class="flex items-center gap-3">
							<img src="/chesson-logo.svg" alt="Chesson" class="h-8 w-auto" />
						</div>
						<p class="mt-4 max-w-sm text-sm text-white/65">
							Play chess online for free: random opponents, bot matches, and offline tournament tools.
						</p>
					</div>

					<div>
						<h3 class="text-sm font-semibold text-white/90">Play</h3>
						<div class="mt-4 space-y-2 text-sm text-white/70">
							<a href="/play-chess-online-free/" class="block hover:text-white">Play chess online for free</a>
							<a href="/play-chess-with-bot/" class="block hover:text-white">Play chess with a bot</a>
							<a href="/play-chess-with-friends-link/" class="block hover:text-white">Play chess with friends</a>
						</div>
					</div>

					<div>
						<h3 class="text-sm font-semibold text-white/90">Chess</h3>
						<div class="mt-4 space-y-2 text-sm text-white/70">
							<a href="/tournaments" class="block hover:text-white">Tournament bracket</a>
							<a href="https://game.chesson.me/" class="block hover:text-white">Game app</a>
							<a href="https://mobile.chesson.me/" class="block hover:text-white">Mobile app</a>
						</div>
					</div>

					<div>
						<h3 class="text-sm font-semibold text-white/90">Team</h3>
						<div class="mt-4 space-y-2 text-sm text-white/70">
							<a href="https://t.me/chessonme" class="block hover:text-white">Telegram</a>
							<a href="/" class="block hover:text-white">English</a>
							<a href="/ru/" class="block hover:text-white">Russian</a>
						</div>
					</div>

					<div>
						<h3 class="text-sm font-semibold text-white/90">Legal</h3>
						<div class="mt-4 space-y-2 text-sm text-white/70">
							<a href="/privacy-policy/" class="block hover:text-white">Privacy Policy</a>
							<a href="/terms-of-use/" class="block hover:text-white">Terms of Use</a>
							<a href="/sitemap-index.xml" class="block hover:text-white">Sitemap</a>
							<a href="/404" class="block hover:text-white">Status</a>
						</div>
					</div>
				</div>

				<div class="mt-10 border-t border-white/10 pt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between text-sm text-white/50">
					<p>© 2026 chesson.me</p>
					<div class="flex items-center gap-4">
						<a href="https://t.me/chessonme" class="hover:text-white">Telegram</a>
						<a href="/ru/" class="hover:text-white">RU</a>
					</div>
				</div>
			</div>
		</footer>
	</main>
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script>
		// Redirect based on screen size
		function redirectBasedOnScreenSize() {
			const isMobile = window.innerWidth < 768 || /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
			
			if (isMobile) {
				window.location.href = 'https://mobile.chesson.me/';
			} else {
				window.location.href = 'https://game.chesson.me/';
			}
		}

		// Add click handler to button
		document.addEventListener('DOMContentLoaded', () => {
			const createRoomBtn = document.getElementById('create-room-btn');
			const ctaPlayNowBtn = document.getElementById('cta-play-now-btn');
			if (createRoomBtn) {
				createRoomBtn.addEventListener('click', (event) => {
					event.preventDefault();
					redirectBasedOnScreenSize();
				});
			}
			if (ctaPlayNowBtn) {
				ctaPlayNowBtn.addEventListener('click', (event) => {
					event.preventDefault();
					redirectBasedOnScreenSize();
				});
			}
		});
	</script>
</Layout>
