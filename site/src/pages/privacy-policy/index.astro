---
import Layout from "../../layouts/Layout.astro";
---

<Layout
	lang="en"
	title="Privacy Policy | chesson.me"
	description="Privacy Policy for chesson.me online chess service."
	canonicalUrl="https://chesson.me/privacy-policy/"
	ogImage="https://chesson.me/og.png"
	locale="en_US"
	alternates={[
		{ lang: "en", url: "https://chesson.me/privacy-policy/" },
		{ lang: "ru", url: "https://chesson.me/ru/privacy-policy/" },
		{ lang: "x-default", url: "https://chesson.me/privacy-policy/" },
	]}
>
	<main class="bg-[#070707] text-white min-h-screen">
		<section class="mx-auto w-[calc(100%-2rem)] max-w-4xl py-14 sm:py-20">
			<h1 class="text-3xl sm:text-4xl font-bold">Privacy Policy</h1>
			<p class="mt-4 text-white/70">Last updated: April 18, 2026</p>

			<div class="mt-10 space-y-10 text-white/85 leading-relaxed">
				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">1. General Information</h2>
					<p class="mt-3">
						The chesson.me website (the "Service") provides users with the ability to play chess online.
					</p>
					<p class="mt-3">
						We respect your privacy and strive to protect user data.
					</p>
					<p class="mt-3">
						By using the website, you agree to this Privacy Policy.
					</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">2. What Data We Collect</h2>
					<p class="mt-3">We may collect the following information:</p>
					<ul class="mt-3 list-disc pl-5 space-y-2">
						<li>Technical data (IP address, browser, device)</li>
						<li>Website usage data (visited pages, actions)</li>
						<li>Data you provide voluntarily (for example, during gameplay or interaction with the service)</li>
					</ul>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">3. Cookies</h2>
					<p class="mt-3">We use cookies for:</p>
					<ul class="mt-3 list-disc pl-5 space-y-2">
						<li>Proper website functionality</li>
						<li>Improving user experience</li>
						<li>Analyzing service usage</li>
					</ul>
					<p class="mt-3">You can disable cookies in your browser settings.</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">4. Analytics</h2>
					<p class="mt-3">
						We may use third-party analytics services (for example, Yandex Metrika or similar tools) to collect anonymized statistics.
					</p>
					<p class="mt-3">This data is used solely to improve the service.</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">5. How We Use Data</h2>
					<p class="mt-3">Collected data is used for:</p>
					<ul class="mt-3 list-disc pl-5 space-y-2">
						<li>Website operation</li>
						<li>Service quality improvements</li>
						<li>Usage analysis</li>
					</ul>
					<p class="mt-3">We do not sell or share your data with third parties unless required.</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">6. Data Retention</h2>
					<p class="mt-3">We retain data only for the period necessary for service operation.</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">7. Security</h2>
					<p class="mt-3">
						We take reasonable measures to protect data, but we cannot guarantee absolute security.
					</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">8. Links to Third-Party Resources</h2>
					<p class="mt-3">
						The website may contain links to third-party resources. We are not responsible for their content or privacy policies.
					</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">9. Policy Changes</h2>
					<p class="mt-3">
						We may update this Policy. By continuing to use the website, you agree to the updated version.
					</p>
				</section>

				<section>
					<h2 class="text-xl sm:text-2xl font-semibold text-white">10. Contacts</h2>
					<p class="mt-3">
						If you have any questions, you can contact us at:
					</p>
					<p class="mt-3">
						Email: <a href="mailto:notifications@chesson.me" class="underline underline-offset-4 hover:text-white">notifications@chesson.me</a>
					</p>
				</section>
			</div>
		</section>
	</main>
</Layout>
