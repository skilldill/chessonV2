---
import SeoLayout from '../../layouts/SeoLayout.astro';
import SeoPageLayout from '../../components/seo/SeoPageLayout.astro';

const title = 'Играть в шахматы с другом онлайн';
const description = 'Играйте в шахматы с другом онлайн по ссылке: бесплатно, в браузере и без установки. Создайте игру за минуту и начните партию.';
const canonicalUrl = 'https://chesson.me/igrat-v-shahmaty-s-drugom/';

const breadcrumbs = [
  { name: 'Главная', url: 'https://chesson.me/' },
  { name: 'Играть в шахматы с другом', url: canonicalUrl },
];

const faq = [
  {
    question: 'Как начать играть в шахматы с другом онлайн?',
    answer: 'Создайте игру, получите ссылку и отправьте другу. После перехода по ссылке партия начинается в одной комнате.',
  },
  {
    question: 'Нужно ли что-то устанавливать?',
    answer: 'Нет. Игра работает в браузере, поэтому дополнительная установка не требуется.',
  },
  {
    question: 'Можно ли играть бесплатно?',
    answer: 'Да, базовый формат игры доступен бесплатно.',
  },
  {
    question: 'Обязательна ли регистрация?',
    answer: 'Для быстрого старта обычно достаточно открыть игру в браузере. Регистрация может быть опциональной.',
  },
  {
    question: 'Подходит ли это для игры с телефона?',
    answer: 'Да, можно играть с мобильного устройства при наличии современного браузера и интернета.',
  },
  {
    question: 'Где создать игру?',
    answer: 'Откройте https://game.chesson.me/ и запустите новую партию.',
  },
];

const hero = {
  h1: 'Играть в шахматы с другом онлайн',
  kicker: 'ChessOn • Friend game',
  summary:
    'Быстрый способ сыграть с другом: создайте комнату, отправьте ссылку и начните партию в браузере без установки.',
  primaryCta: { label: 'Создать игру', href: 'https://game.chesson.me/' },
  secondaryCta: { label: 'Играть по ссылке', href: 'https://game.chesson.me/' },
  ghostCta: { label: 'Правила для новичков', href: '/ru/chess-rules-for-beginners/' },
};

const valueProps = [
  { title: 'Подключение по ссылке', description: 'Одна ссылка ведет прямо в нужную партию без лишних шагов.' },
  { title: 'Быстрый старт', description: 'Создание комнаты занимает меньше минуты.' },
  { title: 'Без установки', description: 'Все работает в браузере на компьютере и телефоне.' },
  { title: 'Удобно для регулярных матчей', description: 'Легко запускать серии дружеских партий.' },
  { title: 'Подходит новичкам', description: 'Понятный вход в игру без технических сложностей.' },
  { title: 'Бесплатно', description: 'Базовый сценарий доступен без оплаты.' },
];

const steps = [
  { title: 'Создайте комнату', description: 'Нажмите «Создать комнату» и откройте новую партию.' },
  { title: 'Скопируйте ссылку', description: 'После создания игры система сгенерирует приглашение.' },
  { title: 'Отправьте другу', description: 'Передайте ссылку в Telegram, WhatsApp, Discord или другом чате.' },
  { title: 'Начинайте матч', description: 'Как только друг откроет ссылку, вы играете на одной доске.' },
];

const useCases = [
  { title: 'Вечерняя партия', description: 'Быстрый матч после работы или учебы.' },
  { title: 'Регулярная практика', description: 'Серия коротких игр для поддержания формы.' },
  { title: 'Обучение в паре', description: 'Удобно тренироваться с другом, который тоже учится.' },
];

const internalLinks = [
  { title: 'Играть в шахматы с друзьями по ссылке', description: 'Подробная страница о формате friend-link.', href: '/ru/play-chess-with-friends-link/' },
  { title: 'Играть в шахматы онлайн бесплатно', description: 'Базовый сценарий браузерных партий.', href: '/ru/play-chess-online-free/' },
  { title: 'Онлайн шахматы без регистрации', description: 'Быстрый вход в игру без лишних шагов.', href: '/ru/online-chess-without-registration/' },
];
---

<SeoLayout
  lang="ru"
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  locale="ru_RU"
  breadcrumbs={breadcrumbs}
  faq={faq}
>
  <SeoPageLayout
    hero={hero}
    valueTitle="Почему удобно играть с другом на ChessOn"
    valueProps={valueProps}
    quickCallout="Запуск за минуту: создать комнату -> отправить ссылку -> начать партию"
    trustTitle="Преимущества"
    trustPoints={['Без установки', 'Работает в браузере', 'Бесплатный старт']}
    howTitle="Как это работает"
    steps={steps}
    useCasesTitle="Когда это особенно полезно"
    useCases={useCases}
    faqTitle="FAQ"
    faq={faq}
    linksTitle="Читайте также"
    links={internalLinks}
    stickyTitle="Быстрый матч"
    stickyText="Создайте комнату и отправьте другу ссылку за минуту."
    stickyCta={{ label: 'Создать игру', href: 'https://game.chesson.me/' }}
  >
    <section class="seo-section">
      <h2>Играть в шахматы с другом без лишней подготовки</h2>
      <p>
        В дружеских шахматных партиях важна не только сама игра, но и скорость старта. Если перед матчем нужно долго настраивать аккаунты,
        искать друг друга в системе и проходить много экранов, часть пользователей просто откладывает игру. Формат ChessOn с приглашением
        по ссылке решает эту проблему: один игрок создает партию, второй подключается по ссылке, и вы сразу переходите к ходам.
      </p>
      <p>
        Такой подход удобен для любых сценариев: от разовой партии вечером до регулярных тренировок в паре. Он подходит и новичкам,
        и тем, кто давно играет, потому что экономит время на организацию и оставляет больше внимания самой доске.
      </p>
    </section>

    <section class="seo-section">
      <h2>Комната с AI-подсказками хода</h2>
      <p>
        В комнате можно включить режим подсказок от AI. В этом формате помощник не делает ход за игрока, а показывает направление стрелкой:
        куда лучше сходить в текущей позиции. Такой вариант удобен, если вы играете с другом и хотите одновременно учиться, разбирать идеи
        и не терять темп партии.
      </p>
      <p>
        Подсказки особенно полезны в учебных матчах: можно обсудить предложенное направление хода, понять логику решения и сразу применить
        идею на доске. Чтобы начать прямо сейчас, перейдите на <a href="https://game.chesson.me/">игровую страницу ChessOn</a>, создайте
        комнату и отправьте приглашение другу. Если нужен расширенный гайд по формату, откройте
        <a href="/ru/play-chess-with-friends-link/">страницу про игру по ссылке</a>.
      </p>
    </section>
  </SeoPageLayout>
</SeoLayout>
