---
import Layout from "../../layouts/Layout.astro";
import { Chessboard3D } from "../../components/Chessboard3D";
---

<Layout 
	lang="ru" 
	title="Играть в шахматы онлайн бесплатно | Chesson"
	description="Играйте в шахматы онлайн бесплатно в браузере: создавайте комнату по ссылке, играйте с ботом и с друзьями без установки."
	canonicalUrl="https://chesson.me/ru/"
	ogImage="https://chesson.me/og.png"
	locale="ru_RU"
	alternates={[
		{ lang: "ru", url: "https://chesson.me/ru/" },
		{ lang: "en", url: "https://chesson.me/" },
		{ lang: "x-default", url: "https://chesson.me/" },
	]}
>
	<div class="relative w-full h-screen bg-black text-white overflow-hidden">
		<header class="absolute top-0 left-0 right-0 z-10 p-9">
			<nav class="flex justify-between items-center max-w-6xl mx-auto">
				<div class="flex items-center">
					<img src="/chesson-logo.svg" alt="Chesson Logo" />
				</div>
			</nav>
		</header>
		<div
			class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-10 text-center w-[calc(100%-2rem)] max-w-4xl"
		>
			<h1 class="font-bold mb-8 max-w-4xl mx-auto text-3xl sm:text-4xl md:text-5xl lg:text-7xl">
				Играть в шахматы онлайн <br> бесплатно с друзьями
			</h1>
			<h2 class="mb-10 font-normal text-xl sm:text-2xl md:text-3xl lg:text-4xl">
				Создай комнату за секунду и начни партию без регистрации
			</h2>
			<div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 w-full sm:w-auto">
				<button
					id="create-room-btn"
					class="w-full sm:w-auto bg-white text-black font-bold py-3 px-6 rounded-md hover:bg-gray-200 transition duration-300 text-lg cursor-pointer"
				>
					Играть
				</button>
				<button
					id="login-btn"
					class="w-full sm:w-auto bg-[#4F39F6] text-white border border-[#6D5BFF] font-bold py-3 px-6 rounded-md hover:bg-[#5C47FF] shadow-[0_8px_24px_rgba(79,57,246,0.45)] transition duration-300 text-lg cursor-pointer"
				>
					Войти
				</button>
				<a
					href="/tournaments"
					class="relative w-full sm:w-auto bg-[#1f2937] text-white border border-[#374151] font-bold py-3 px-6 rounded-md hover:bg-[#111827] transition duration-300 text-lg text-center"
				>
					Создать турнирную сетку
					<span class="absolute -top-2 -right-2 inline-block rounded bg-[#4F39F6] px-2 py-0.5 text-[10px] leading-none uppercase rotate-12 shadow-[0_4px_14px_rgba(79,57,246,0.55)]">beta</span>
				</a>
			</div>
		</div>
		<Chessboard3D client:only />
		<nav aria-label="Ключевые страницы" class="absolute left-0 right-0 bottom-[86px] sm:bottom-[106px] z-10">
			<div class="mx-auto grid w-[calc(100%-2rem)] max-w-[360px] grid-cols-2 gap-x-3 gap-y-1 sm:flex sm:max-w-5xl sm:flex-wrap sm:items-center sm:justify-center sm:gap-3">
				<a href="/ru/play-chess-online-free/" class="col-span-2 sm:col-span-1 text-xs text-white/90 text-center underline underline-offset-4 decoration-white/30 hover:text-white sm:rounded-md sm:border sm:border-[#374151] sm:bg-[#111827]/90 sm:px-3 sm:py-2 sm:text-sm sm:no-underline sm:leading-tight sm:min-h-[42px] sm:flex sm:items-center sm:justify-center sm:hover:bg-[#1f2937]">
					Играть в шахматы онлайн бесплатно
				</a>
				<a href="/ru/play-chess-with-bot/" class="col-span-2 sm:col-span-1 text-xs text-white/90 text-center underline underline-offset-4 decoration-white/30 hover:text-white sm:rounded-md sm:border sm:border-[#374151] sm:bg-[#111827]/90 sm:px-3 sm:py-2 sm:text-sm sm:no-underline sm:leading-tight sm:min-h-[42px] sm:flex sm:items-center sm:justify-center sm:hover:bg-[#1f2937]">
					Играть в шахматы с ботом
				</a>
				<a href="/ru/play-chess-with-friends-link/" class="text-xs text-white/90 text-center underline underline-offset-4 decoration-white/30 hover:text-white sm:rounded-md sm:border sm:border-[#374151] sm:bg-[#111827]/90 sm:px-3 sm:py-2 sm:text-sm sm:no-underline sm:leading-tight sm:min-h-[42px] sm:flex sm:items-center sm:justify-center sm:hover:bg-[#1f2937]">
					Играть в шахматы с другом
				</a>
				<a href="/" class="text-xs text-[#9f90ff] text-center underline underline-offset-4 decoration-[#6D5BFF]/50 hover:text-[#c9c0ff] sm:rounded-md sm:border sm:border-[#6D5BFF] sm:bg-[#4F39F6]/90 sm:px-3 sm:py-2 sm:text-sm sm:text-white sm:no-underline sm:leading-tight sm:min-h-[42px] sm:flex sm:items-center sm:justify-center sm:hover:bg-[#5C47FF]">
					en
				</a>
			</div>
		</nav>
		<div class="absolute left-0 bottom-[40px] right-0">
			<div class="text-center text-xm opacity-70 flex flex-col md:flex-row items-center justify-center gap-1 md:gap-0">
				<a href="https://t.me/chessonme" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 transition-opacity order-1 md:order-3">
					<span class="order-2 md:order-1">v0.12.1 + <span class="font-extrabold bg-gradient-to-r from-[#E810A7] to-[#FFE600] bg-clip-text text-transparent italic">AI features</span></span>
				</a>
			</div>
		</div>
	</div>
	<script>
		// Redirect based on screen size
		function redirectBasedOnScreenSize() {
			const isMobile = window.innerWidth < 768 || /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
			
			if (isMobile) {
				window.location.href = 'https://mobile.chesson.me/';
			} else {
				window.location.href = 'https://game.chesson.me/';
			}
		}

		function redirectToLogin() {
			window.location.href = '/login';
		}
		
		// Add click handler to button
		document.addEventListener('DOMContentLoaded', () => {
			const createRoomBtn = document.getElementById('create-room-btn');
			const loginBtn = document.getElementById('login-btn');
			if (createRoomBtn) {
				createRoomBtn.addEventListener('click', redirectBasedOnScreenSize);
			}
			if (loginBtn) {
				loginBtn.addEventListener('click', redirectToLogin);
			}
		});
	</script>
</Layout>
