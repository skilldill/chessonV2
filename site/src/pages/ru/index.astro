---
import Layout from "../../layouts/Layout.astro";
import { Chessboard3D } from "../../components/Chessboard3D";

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: [
		{
			"@type": "Question",
			name: "Можно ли играть в шахматы онлайн бесплатно?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "Да. На chesson.me можно играть в шахматы онлайн бесплатно прямо в браузере.",
			},
		},
		{
			"@type": "Question",
			name: "Нужна ли регистрация для старта?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "Нет. Игру можно начать без обязательной регистрации.",
			},
		},
		{
			"@type": "Question",
			name: "Можно ли играть против бота?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "Да. Доступны онлайн шахматы с компьютером и выбор подходящего уровня сложности.",
			},
		},
		{
			"@type": "Question",
			name: "Работает ли сервис на телефоне и ПК?",
			acceptedAnswer: {
				"@type": "Answer",
				text: "Да. chesson.me стабильно работает в современных браузерах на мобильных устройствах и компьютерах.",
			},
		},
	],
};
---

<Layout 
	lang="ru" 
	title="Играть в шахматы онлайн бесплатно | Chesson"
	description="Играйте в шахматы онлайн бесплатно в браузере: создавайте комнату по ссылке, играйте с ботом и с друзьями без установки."
	canonicalUrl="https://chesson.me/ru/"
	ogImage="https://chesson.me/og.png"
	locale="ru_RU"
	alternates={[
		{ lang: "ru", url: "https://chesson.me/ru/" },
		{ lang: "en", url: "https://chesson.me/" },
		{ lang: "x-default", url: "https://chesson.me/" },
	]}
>
	<main class="bg-[#070707] text-white">
		<section class="relative w-full h-screen overflow-hidden">
			<header class="absolute top-0 left-0 right-0 z-10 p-9">
				<nav class="flex justify-between items-center max-w-6xl mx-auto">
					<div class="flex items-center">
						<img src="/chesson-logo.svg" alt="Chesson Logo" />
					</div>
				</nav>
			</header>
			<div
				class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-10 text-center w-[calc(100%-2rem)] max-w-4xl  flex flex-col justify-center items-center h-full"
			>
				<h1 class="font-bold mb-8 max-w-4xl mx-auto text-3xl sm:text-4xl md:text-5xl lg:text-7xl">
					Играй в шахматы онлайн бесплатно <br> с соперниками и ботом
				</h1>
				<h2 class="mb-10 font-normal text-3xl">
					Создай комнату за секунду и начни партию без регистрации
				</h2>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 w-full sm:w-auto">
					<a
						id="create-room-btn"
						href="https://game.chesson.me/"
						class="w-full sm:w-auto bg-white text-black font-bold py-3 px-6 rounded-md hover:bg-gray-200 transition duration-300 text-lg cursor-pointer"
					>
						Играть
					</a>
				</div>
			</div>
			<Chessboard3D client:idle />
			<div class="absolute left-0 bottom-[40px] right-0 z-[10]">
				<div class="text-center text-xm opacity-70 flex flex-col md:flex-row items-center justify-center gap-1 md:gap-0">
					<a href="https://t.me/chessonme" target="_blank" rel="noopener noreferrer" class="hover:opacity-100 transition-opacity order-1 md:order-3">
						<span class="order-2 md:order-1">v0.12.1 + <span class="font-extrabold bg-gradient-to-r from-[#E810A7] to-[#FFE600] bg-clip-text text-transparent italic">AI features</span></span>
					</a>
				</div>
			</div>
		</section>

		<section class="mx-auto w-[calc(100%-2rem)] max-w-5xl py-16 sm:py-20">
			<div class="rounded-2xl border border-[#2A2A2A] bg-[#0F0F0F] p-6 sm:p-10 text-center">
				<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold">Создать турнирную сетку для оффлайн-игры</h2>
				<p class="mt-4 text-sm sm:text-lg text-white/80">
					Используй инструмент сетки, чтобы организовать оффлайн-турнир, вести раунды и фиксировать победителей в одном месте.
				</p>
				<a
					href="/tournaments"
					class="relative mt-8 inline-block w-full sm:w-auto bg-[#1f2937] text-white border border-[#374151] font-bold py-3 px-6 rounded-md hover:bg-[#111827] transition duration-300 text-lg text-center"
				>
					Создать турнирную сетку
					<span class="absolute -top-2 -right-2 inline-block rounded bg-[#4F39F6] px-2 py-0.5 text-[10px] leading-none uppercase rotate-12 shadow-[0_4px_14px_rgba(79,57,246,0.55)]">beta</span>
				</a>
			</div>
		</section>

		<section class="mx-auto w-[calc(100%-2rem)] max-w-5xl py-16 sm:py-20">
			<div class="rounded-2xl border border-[#2A2A2A] bg-[#111111] p-6 sm:p-10 text-center">
				<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold">Играй в шахматы онлайн бесплатно</h2>
				<p class="mt-4 text-sm sm:text-lg text-white/80">Без регистрации. Случайные соперники и игра с ботом.</p>
				<a
					id="cta-play-now-btn"
					href="https://game.chesson.me/"
					class="mt-8 w-full sm:w-auto bg-white text-black font-bold py-3 px-7 rounded-md hover:bg-gray-200 transition duration-300 text-lg cursor-pointer"
				>
					Играть сейчас
				</a>
				<ul class="mt-8 space-y-2 text-sm sm:text-base text-white/90">
					<li>Случайный соперник онлайн</li>
					<li>Игра с ботом (3 уровня сложности)</li>
					<li>Подсказки от AI</li>
				</ul>
			</div>
		</section>

		<section class="mx-auto w-[calc(100%-2rem)] max-w-5xl pb-16 sm:pb-20">
			<div class="rounded-2xl border border-[#2A2A2A] bg-[#0D0D0D] p-6 sm:p-10">
				<h2 class="text-2xl sm:text-3xl font-bold text-center">Почему chesson?</h2>
				<ul class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm sm:text-base">
					<li class="rounded-xl border border-[#222222] bg-[#121212] px-4 py-3">Играй без регистрации</li>
					<li class="rounded-xl border border-[#222222] bg-[#121212] px-4 py-3">Быстрый старт игры</li>
					<li class="rounded-xl border border-[#222222] bg-[#121212] px-4 py-3">Работает на телефоне и ПК</li>
					<li class="rounded-xl border border-[#222222] bg-[#121212] px-4 py-3">Бесплатно и без ограничений</li>
				</ul>
			</div>
		</section>

		<section class="mx-auto w-[calc(100%-2rem)] max-w-5xl pb-16 sm:pb-20" aria-labelledby="faq-title">
			<div class="rounded-2xl border border-[#2A2A2A] bg-[#111111] p-6 sm:p-10">
				<h2 id="faq-title" class="text-2xl sm:text-3xl font-bold text-center">FAQ</h2>
				<div class="mt-8 space-y-3">
					<details class="rounded-xl border border-[#222222] bg-[#121212] px-4 py-3">
						<summary class="cursor-pointer font-semibold">Можно ли играть в шахматы онлайн бесплатно?</summary>
						<p class="mt-2 text-white/80">Да. На chesson.me можно играть в шахматы онлайн бесплатно прямо в браузере.</p>
					</details>
					<details class="rounded-xl border border-[#222222] bg-[#121212] px-4 py-3">
						<summary class="cursor-pointer font-semibold">Нужна ли регистрация для старта?</summary>
						<p class="mt-2 text-white/80">Нет. Игру можно начать без обязательной регистрации.</p>
					</details>
					<details class="rounded-xl border border-[#222222] bg-[#121212] px-4 py-3">
						<summary class="cursor-pointer font-semibold">Можно ли играть против бота?</summary>
						<p class="mt-2 text-white/80">Да. Доступны онлайн шахматы с компьютером и выбор подходящего уровня сложности.</p>
					</details>
					<details class="rounded-xl border border-[#222222] bg-[#121212] px-4 py-3">
						<summary class="cursor-pointer font-semibold">Работает ли сервис на телефоне и ПК?</summary>
						<p class="mt-2 text-white/80">Да. chesson.me стабильно работает в современных браузерах на мобильных устройствах и компьютерах.</p>
					</details>
				</div>
			</div>
		</section>

		<section class="mx-auto w-[calc(100%-2rem)] max-w-5xl pb-16 sm:pb-20" aria-labelledby="seo-text-title">
			<div class="rounded-2xl border border-[#2A2A2A] bg-[#101010] p-6 sm:p-8 text-sm sm:text-base leading-relaxed text-white/85">
				<h2 id="seo-text-title" class="text-xl sm:text-2xl font-semibold text-white">Играть в шахматы онлайн легко</h2>
				<p class="mt-4">
					На chesson.me можно <strong>играть в шахматы онлайн</strong> прямо в браузере за пару кликов. Платформа подходит для быстрых партий в течение дня и для длинных матчей вечером.
				</p>
				<p class="mt-4">
					Если вам нужны <strong>шахматы онлайн бесплатно</strong>, вы сразу переходите к игре: создаете комнату, находите соперника или запускаете матч против бота. Это удобная <strong>игра в шахматы без регистрации</strong> без лишних шагов перед началом.
				</p>
				<p class="mt-4">
					Также доступны <strong>онлайн шахматы с компьютером</strong> для тренировки тактики и практики в своем темпе. Сервис стабильно работает на телефоне и ПК, поэтому можно играть там, где удобно.
				</p>
			</div>
		</section>

		<footer class="mx-auto w-[calc(100%-2rem)] max-w-5xl pb-16 sm:pb-20" aria-label="Footer links">
			<div class="rounded-2xl border border-[#2A2A2A] bg-[#0D0D0D] p-6 sm:p-8">
				<p class="text-sm font-semibold text-white/90">Быстрые ссылки</p>
				<div class="mt-4 flex flex-col sm:flex-row sm:flex-wrap gap-3 text-sm">
					<a href="/ru/play-chess-online-free/" class="text-white/80 hover:text-white underline underline-offset-4 decoration-white/30">Играть в шахматы онлайн бесплатно</a>
					<a href="/ru/play-chess-with-bot/" class="text-white/80 hover:text-white underline underline-offset-4 decoration-white/30">Играть в шахматы с ботом</a>
					<a href="/ru/play-chess-with-friends-link/" class="text-white/80 hover:text-white underline underline-offset-4 decoration-white/30">Играть в шахматы с другом</a>
					<a href="/" class="text-[#b2a8ff] hover:text-[#d1c9ff] underline underline-offset-4 decoration-[#6D5BFF]/50">en</a>
				</div>
			</div>
		</footer>
	</main>
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script>
		// Redirect based on screen size
		function redirectBasedOnScreenSize() {
			const isMobile = window.innerWidth < 768 || /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
			
			if (isMobile) {
				window.location.href = 'https://mobile.chesson.me/';
			} else {
				window.location.href = 'https://game.chesson.me/';
			}
		}

		// Add click handler to button
		document.addEventListener('DOMContentLoaded', () => {
			const createRoomBtn = document.getElementById('create-room-btn');
			const ctaPlayNowBtn = document.getElementById('cta-play-now-btn');
			if (createRoomBtn) {
				createRoomBtn.addEventListener('click', (event) => {
					event.preventDefault();
					redirectBasedOnScreenSize();
				});
			}
			if (ctaPlayNowBtn) {
				ctaPlayNowBtn.addEventListener('click', (event) => {
					event.preventDefault();
					redirectBasedOnScreenSize();
				});
			}
		});
	</script>
</Layout>
