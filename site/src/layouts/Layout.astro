---
import '../styles/global.css';

const {
	lang,
	title,
	description,
	canonicalUrl,
	ogImage,
	locale,
	alternates = [],
} = Astro.props;

const siteUrl = "https://chesson.me/";
const websiteId = `${siteUrl}#website`;
const orgId = `${siteUrl}#organization`;

const webSiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"@id": websiteId,
	name: "ChessOn",
	url: siteUrl,
	inLanguage: [lang],
	publisher: { "@id": orgId },
};

const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"@id": orgId,
	name: "ChessOn",
	url: siteUrl,
	logo: `${siteUrl}favicon.png`,
};

const webPageSchema = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": `${canonicalUrl}#webpage`,
	url: canonicalUrl,
	name: title,
	description,
	inLanguage: lang,
	isPartOf: { "@id": websiteId },
	about: { "@id": orgId },
	primaryImageOfPage: {
		"@type": "ImageObject",
		url: ogImage,
	},
};

const breadcrumbItems = [
	{
		"@type": "ListItem",
		position: 1,
		name: lang === "ru" ? "Главная" : "Home",
		item: siteUrl,
	},
];

if (canonicalUrl !== siteUrl) {
	breadcrumbItems.push({
		"@type": "ListItem",
		position: 2,
		name: title,
		item: canonicalUrl,
	});
}

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: breadcrumbItems,
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<title>
			{title}
		</title>
		<meta
			name="description"
			content={description}
		/>
		<meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="canonical" href={canonicalUrl} />
		{alternates.map((alternate: { lang: string; url: string }) => (
			<link rel="alternate" hreflang={alternate.lang} href={alternate.url} />
		))}

		<link rel="icon" href="/favicon.png" sizes="64x64" type="image/png">
		<meta name="theme-color" content="#000000">
		<meta name="generator" content={Astro.generator} />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta
			property="og:description"
			content={description}
		/>
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta
			property="og:image"
			content={ogImage}
		/>
		<meta property="og:site_name" content="Chesson" />
		<meta property="og:locale" content={locale} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta
			name="twitter:description"
			content={description}
		/>
		<meta
			name="twitter:image"
			content={ogImage}
		/>
		<meta name="yandex-verification" content="38dcf07e3f7f734f" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

		<!-- Yandex.Metrika counter -->
		<script type="text/javascript">
			(function(m,e,t,r,i,k,a){
				m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
				m[i].l=1*new Date();
				for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
				k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
			})(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=105020689', 'ym');

			ym(105020689, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", accurateTrackBounce:true, trackLinks:true});
		</script>
		<!-- /Yandex.Metrika counter -->
	</head>

	<body>
		<noscript><div><img src="https://mc.yandex.ru/watch/105020689" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
		<slot />
		<div id="cookie-banner" class="cookie-banner" hidden>
			<div class="cookie-content">
				<p class="cookie-text">
					{lang === "en"
						? "By continuing to use this site, you agree to the use of cookies and anonymized data processing for analytics and service improvements."
						: "Продолжая оставаться на сайте, вы соглашаетесь на использование cookie-файлов и обработку обезличенных данных для аналитики и улучшения сервиса."}
				</p>
				<button id="cookie-ok" type="button" class="cookie-btn">Ок</button>
			</div>
		</div>
		<script>
			(function () {
				const COOKIE_KEY = "chesson_cookie_banner_accepted_v1";
				const banner = document.getElementById("cookie-banner");
				const okBtn = document.getElementById("cookie-ok");
				if (!banner || !okBtn) return;

				try {
					if (localStorage.getItem(COOKIE_KEY) === "1") {
						banner.hidden = true;
						return;
					}
				} catch (e) {
					// localStorage may be unavailable
				}

				banner.hidden = false;

				okBtn.addEventListener("click", function () {
					try {
						localStorage.setItem(COOKIE_KEY, "1");
					} catch (e) {
						// localStorage may be unavailable
					}
					banner.hidden = true;
				});
			})();
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background: #000;
	}
	body {
		padding-top: env(safe-area-inset-top);
		padding-bottom: env(safe-area-inset-bottom);
	}
	.cookie-banner {
		position: fixed;
		left: 16px;
		right: 16px;
		bottom: calc(16px + env(safe-area-inset-bottom));
		z-index: 9999;
		border: 1px solid #2a2a2a;
		border-radius: 12px;
		background: rgba(14, 14, 14, 0.98);
		box-shadow: 0 14px 30px rgba(0, 0, 0, 0.45);
	}
	.cookie-content {
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 14px;
	}
	.cookie-text {
		margin: 0;
		font-size: 13px;
		line-height: 1.45;
		color: #d0d0d0;
	}
	.cookie-btn {
		height: 36px;
		align-self: flex-end;
		padding: 0 16px;
		border: 1px solid #ffffff;
		border-radius: 8px;
		background: #ffffff;
		color: #111111;
		font-size: 13px;
		font-weight: 600;
		cursor: pointer;
	}
	@media (min-width: 768px) {
		.cookie-banner {
			left: 24px;
			right: 24px;
		}
		.cookie-content {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			gap: 20px;
		}
		.cookie-text {
			max-width: 840px;
			font-size: 14px;
		}
	}
</style>
